#!/usr/bin/env bash

set -e

if [[ -n "${DEBUG}" ]]; then
  set -x
fi

provider=$1
key=$2
secret=$3
dir=$4
gzip=$5
exclude_paths=$6
mark=$7
bucket=$8
destination=$9
max_concurrent_requests=${10}
max_bandwidth=${11}
storage_class=${12}
content_disposition=${13}
region=${14}
endpoint_url=${15}

case "${provider}" in
"aws")
  if [[ -z "${secret}" ]]; then
    echo >&2 "Missing AWS secret access key"
    exit 1
  fi
  storage_class=${storage_class:-STANDARD}
  AWS_REGION=${region} AWS_ACCESS_KEY_ID=${key} AWS_SECRET_ACCESS_KEY=${secret} backup_and_upload_aws \
    "${dir}" "${gzip}" "${exclude_paths}" "${mark}" \
    "${bucket}" "${destination}" "${max_concurrent_requests}" "${max_bandwidth}" "${storage_class}" "${content_disposition}" "${endpoint_url}"
  ;;
"azure")
  if [[ -z "${secret}" ]]; then
    echo >&2 "Missing Azure storage account key"
    exit 1
  fi
  backup_and_upload_azure \
    "${dir}" "${gzip}" "${exclude_paths}" "${mark}" \
    "${key}" "${secret}" "${bucket}" "${destination}" \
    "${max_concurrent_requests}" "${max_bandwidth}" "${storage_class}" "${content_disposition}" "${endpoint_url}"
  ;;
"gcp")
  if [[ ! -f "${key}" ]]; then
    echo "${key}" | base64 -d >/tmp/sa.json
    key=/tmp/sa.json
  fi
  backup_and_upload_gcp \
    "${dir}" "${gzip}" "${exclude_paths}" "${mark}" \
    "${key}" "${bucket}" "${destination}" "${storage_class}" "${content_disposition}"
  ;;
*)
  if [[ -z "${secret}" ]]; then
    echo >&2 "Missing S3 secret access key"
    exit 1
  fi
  if [[ -z "${endpoint_url}" ]]; then
    echo >&2 "Missing S3 endpoint URL"
    exit 1
  fi
  AWS_REGION=${region} AWS_ACCESS_KEY_ID=${key} AWS_SECRET_ACCESS_KEY=${secret} backup_and_upload_aws \
    "${dir}" "${gzip}" "${exclude_paths}" "${mark}" \
    "${bucket}" "${destination}" "${max_concurrent_requests}" "${max_bandwidth}" "${storage_class}" "${content_disposition}" "${endpoint_url}"
  ;;
esac
