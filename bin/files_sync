#!/usr/bin/env bash

set -eo pipefail

if [[ -n "${DEBUG}" ]]; then
    set -x
fi

from="${1}"
to="${2}"
owner="${3}"
group="${4}"
delete="${5}"

params=""

if [[ -n "${owner}" && "${group}" ]]; then
  echo "Owner and group specified, using rsync with chown"
  params="${params} --chown=\"${owner}:${group}\""
fi

if [[ -n "${delete}" ]]; then
  echo "Delete flag specified. Will delete files in destination that are not in source"
  params="${params} --delete"
fi

rsync -rltpog "${params}" "${from}" "${to}"
