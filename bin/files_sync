#!/usr/bin/env bash

set -eo pipefail

if [[ -n "${DEBUG}" ]]; then
    set -x
fi

from="${1}"
to="${2}"
delete="${3}"
owner="${4}"
group="${5}"

chown=""
del=""

if [[ -n "${owner}" && -n "${group}" && "${owner}" != "0" && "${group}" != "0" ]]; then
  echo "Owner and group specified, using rsync with chown"
  chown="--chown=${owner}:${group}"
fi

if [[ -n "${delete}" && "${delete}" != "0" ]]; then
  echo "Delete flag specified. Will delete files in destination that are not in source"
  del="--delete"
fi

rsync -rltpog ${chown} ${del} "${from}" "${to}"
